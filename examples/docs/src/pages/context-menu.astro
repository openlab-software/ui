---
import DocsLayout from "../layouts/DocsLayout.astro";
import { ContextMenuBasic } from "../components/previews/react/ContextMenuPreview";
import ContextMenuPreviewVue from "../components/previews/vue/ContextMenuPreview.vue";
---

<DocsLayout
  title="Context Menu"
  description="Displays a menu at the pointer's position when a user right-clicks or long-presses."
  activeId="context-menu"
>
  <div class="docs-section">
    <h2 class="docs-section-title">Basic</h2>
    <div class="fw-panel" data-fw="react">
      <div class="docs-preview">
        <ContextMenuBasic client:load />
      </div>
      <div class="docs-code">
        <div class="docs-code-header"><span>tsx</span></div>
        <div class="docs-code-body">
          <pre>{`import {
  ContextMenu,
  ContextMenuContent,
  ContextMenuItem,
  ContextMenuSeparator,
  ContextMenuLabel,
  ContextMenuGroup,
  ContextMenuShortcut,
} from "@openlab-ui/react";

<ContextMenu>
  <div onContextMenu={...}>Right-click here</div>
  <ContextMenuContent>
    <ContextMenuGroup>
      <ContextMenuLabel>Actions</ContextMenuLabel>
      <ContextMenuItem>
        Open <ContextMenuShortcut>↵</ContextMenuShortcut>
      </ContextMenuItem>
      <ContextMenuItem>
        Copy link <ContextMenuShortcut>⌘C</ContextMenuShortcut>
      </ContextMenuItem>
    </ContextMenuGroup>
    <ContextMenuSeparator />
    <ContextMenuItem variant="destructive">Delete</ContextMenuItem>
  </ContextMenuContent>
</ContextMenu>`}</pre>
        </div>
      </div>
    </div>
    <div class="fw-panel" data-fw="vue" hidden>
      <div class="docs-preview">
        <ContextMenuPreviewVue client:load />
      </div>
      <div class="docs-code">
        <div class="docs-code-header"><span>vue</span></div>
        <div class="docs-code-body">
          <pre>{`<script setup>
import {
  ContextMenu, ContextMenuContent, ContextMenuItem,
  ContextMenuSeparator, ContextMenuLabel,
  ContextMenuGroup, ContextMenuShortcut,
} from "@openlab-ui/vue";
</script>

<template>
  <ContextMenu>
    <div>Right-click here</div>
    <ContextMenuContent>
      <ContextMenuGroup>
        <ContextMenuLabel>Actions</ContextMenuLabel>
        <ContextMenuItem>
          Open <ContextMenuShortcut>↵</ContextMenuShortcut>
        </ContextMenuItem>
      </ContextMenuGroup>
      <ContextMenuSeparator />
      <ContextMenuItem variant="destructive">Delete</ContextMenuItem>
    </ContextMenuContent>
  </ContextMenu>
</template>`}</pre>
        </div>
      </div>
    </div>
  </div>
</DocsLayout>
