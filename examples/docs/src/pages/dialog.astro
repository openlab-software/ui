---
import DocsLayout from "../layouts/DocsLayout.astro";
import { DialogBasic } from "../components/previews/react/DialogPreview";
import DialogPreviewVue from "../components/previews/vue/DialogPreview.vue";
---

<DocsLayout title="Dialog" description="A modal window for presenting critical information or actions." activeId="dialog">
  <div class="docs-section">
    <h2 class="docs-section-title">Basic</h2>
    <div class="fw-panel" data-fw="react">
      <div class="docs-preview docs-preview-center">
        <DialogBasic client:load />
      </div>
      <div class="docs-code">
        <div class="docs-code-header"><span>tsx</span></div>
        <div class="docs-code-body"><pre>{`import {
  Dialog, DialogTrigger, DialogContent,
  DialogHeader, DialogTitle, DialogDescription, DialogFooter
} from "@openlab-ui/react";

<Dialog>
  <DialogTrigger asChild>
    <Button>Open Dialog</Button>
  </DialogTrigger>
  <DialogContent>
    <DialogHeader>
      <DialogTitle>Edit Profile</DialogTitle>
      <DialogDescription>Make changes here.</DialogDescription>
    </DialogHeader>
    <DialogFooter>
      <Button>Save Changes</Button>
    </DialogFooter>
  </DialogContent>
</Dialog>`}</pre></div>
      </div>
    </div>
    <div class="fw-panel" data-fw="vue" hidden>
      <div class="docs-preview docs-preview-center">
        <DialogPreviewVue client:load />
      </div>
      <div class="docs-code">
        <div class="docs-code-header"><span>vue</span></div>
        <div class="docs-code-body"><pre>{`<script setup>
import {
  Dialog, DialogTrigger, DialogContent,
  DialogHeader, DialogTitle, DialogDescription, DialogFooter
} from "@openlab-ui/vue";
import { ref } from "vue";
const open = ref(false);
</script>

<template>
  <Dialog v-model="open">
    <DialogTrigger as-child>
      <Button>Open Dialog</Button>
    </DialogTrigger>
    <DialogContent>
      <DialogHeader>
        <DialogTitle>Edit Profile</DialogTitle>
      </DialogHeader>
      <DialogFooter>
        <Button @click="open = false">Save Changes</Button>
      </DialogFooter>
    </DialogContent>
  </Dialog>
</template>`}</pre></div>
      </div>
    </div>
  </div>
</DocsLayout>
