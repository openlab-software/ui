{
  "name": "@openlab-ui/openlab-ui",
  "directories": {
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openlab-software/ui.git"
  },
  "author": "https://github.com/patrickdevbr",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/openlab-software/ui/issues"
  },
  "homepage": "https://github.com/openlab-software/ui#readme",
  "private": true,
  "devDependencies": {
    "pnpm": "^8.0.0"
  },
  "scripts": {
    "dev:react": "pnpm --filter example-react dev",
    "dev:vue": "pnpm --filter example-vue dev",
    "build": "pnpm -r --if-present build",
    "build:packages": "pnpm --filter vue --filter react build -w",
    "bootstrap": "pnpm install && pnpm -w -r build"
  }
}
